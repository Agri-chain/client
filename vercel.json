{
  "version": 2,
  "name": "agrchain-client",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://your-server-url.vercel.app/api/v1",
    "VITE_GOOGLE_CLIENT_ID": "404956463332-2vdnp7fg6j2qsm1gnh4u1of6o9b6iqpn.apps.googleusercontent.com"
  }
}
